# MySQL/MariaDB Configuration (MariaDB running on port 3306)
DATABASE_URL=mysql+pymysql://root@127.0.0.1:3306/furniture_db

# If your MySQL has a password, uncomment and use this instead:
# DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/furniture_db

# Database will be created automatically if it doesn't exist
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEBUG=True